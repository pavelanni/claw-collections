{
  "agents": {
    "list": [
      {
        "id": "default",
        "default": true,
        "name": "Software Q&A",
        "workspace": "~/.openclaw/workspace",
        "subagents": { "allowAgents": ["docs-checker"] }
      },
      {
        "id": "docs-checker",
        "name": "Docs Checker",
        "workspace": "~/.openclaw/workspace-docs-checker",
        "model": { "primary": "anthropic/claude-sonnet-4-6", "fallbacks": ["openai/gpt-5.4"] }
      }
    ]
  },
  "mcp": {
    "servers": {
      "context7": {
        "url": "https://mcp.context7.com/mcp",
        "transport": "streamable-http"
      }
    }
  }
}
